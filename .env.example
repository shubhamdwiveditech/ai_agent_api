# ---- App ----
APP_NAME=ai_agent_api
APP_ENV=development
API_KEY=replace-with-a-strong-random-string

# ---- OpenAI ----
OPENAI_API_KEY=sk-...
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# ---- Supabase (REST, no SDK) ----
# Project URL, e.g. https://xyzcompany.supabase.co
SUPABASE_URL=https://your-project.supabase.co
# Use the service_role key on the server (NEVER ship to client)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
# Optional: anon key if you need a separate read-only client
SUPABASE_ANON_KEY=

# ---- HTTP ----
HTTP_TIMEOUT_SECONDS=60
