{
  "openapi": "3.0.0",
  "info": {
    "title": "AI Service API",
    "version": "1.0.0",
    "description": ""
  },
  "servers": [
    {
      "url": "{{url}}"
    }
  ],
  "paths": {
    "/auth/token": {
      "post": {
        "summary": "Token",
        "responses": {},
        "tags": [
          "Auth"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email"
                  },
                  "password": {
                    "type": "string"
                  }
                }
              },
              "example": {
                "email": "shubham.dwivedi.tech@gmail.com",
                "password": "Shubham@123"
              }
            }
          }
        }
      }
    },
    "/chat": {
      "post": {
        "summary": "Chat",
        "responses": {},
        "tags": [
          "Auth"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "agent_id": {
                    "type": "integer"
                  },
                  "session_id": {
                    "type": "string",
                    "format": "utc-millisec"
                  },
                  "message": {
                    "type": "string"
                  }
                }
              },
              "example": {
                "agent_id": 5,
                "session_id": "14",
                "message": "how can you help me?"
              }
            }
          }
        }
      }
    },
    "/embed": {
      "post": {
        "summary": "Embed",
        "responses": {},
        "tags": [
          "Auth"
        ],
        "security": [
          {
            "BearerAuth": []
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "id": {
                    "type": "integer"
                  }
                }
              },
              "example": {
                "id": 1
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "BearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  }
}